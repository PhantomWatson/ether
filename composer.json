{
	"name" : "phantomwatson/ether",
	"description" : "The Ether - Thought Repository",
	"homepage" : "https://theether.com",
	"type" : "project",
	"license" : "proprietary",
	"require" : {
		"php": ">=8.5",
		"ext-curl": "*",
		"ext-json": "*",
		"alek13/slack": "^2.0",
		"cakephp/authentication": "^4.2",
		"cakephp/cakephp": "5.3.*",
		"cakephp/migrations": "^5.0",
		"cakephp/plugin-installer": "^2.0",
		"flesler/jquery.scrollto": "*",
		"google/cloud-text-to-speech": "^1.4",
		"league/commonmark": "*",
		"mobiledetect/mobiledetectlib": "^4.8.03",
		"phantomwatson/ether-markov": "*",
		"twbs/bootstrap": "^5.1.3"
	},
	"require-dev" : {
		"cakephp/bake": "^3.6",
		"cakephp/cakephp-codesniffer": "^5.3",
		"cakephp/debug_kit": "^5.2",
		"dereuromark/cakephp-ide-helper": "^2.22",
		"josegonzalez/dotenv": "^4.0",
		"league/html-to-markdown": "~4.0",
		"phpunit/phpunit": "^11.5.3 || ^12.1.3 || ^13.0",
		"psy/psysh": "@stable"
	},
	"suggest" : {
		"phpunit/phpunit" : "Allows automated tests to be run without system-wide install.",
		"cakephp/cakephp-codesniffer" : "Allows to check the code against the coding standards used in CakePHP."
	},
	"autoload" : {
		"psr-4" : {
			"App\\" : "src"
		}
	},
	"autoload-dev" : {
		"psr-4" : {
			"App\\Test\\" : "tests",
			"Cake\\Test\\" : "./vendor/cakephp/cakephp/tests",
			"HTML_To_Markdown\\": "./vendor/league/html-to-markdown"
		}
	},
	"scripts" : {
        "post-install-cmd": "App\\Console\\Installer::postInstall",
        "post-create-project-cmd": "App\\Console\\Installer::postInstall",
        "check": [
            "@test",
            "@cs-check"
        ],
        "cs-check": "phpcs --colors -p  src/ tests/",
        "cs-fix": "phpcbf --colors -p src/ tests/",
        "stan": "phpstan analyse",
        "test": "phpunit --colors=always"
	},
	"minimum-stability" : "dev",
	"prefer-stable" : true,
	"config": {
        "platform-check": true,
        "sort-packages": true,
        "allow-plugins": {
            "cakephp/plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
	}
}
